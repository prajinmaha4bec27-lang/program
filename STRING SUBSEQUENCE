import sys


inputs = sys.stdin.read().split()

if len(inputs) >= 2:
    s1 = inputs[0]
    s2 = inputs[1]
    
    i = 0  # Pointer for s1
    j = 0  # Pointer for s2
    
  
    while i < len(s1) and j < len(s2):
       
        if s1[i] == s2[j]:
            i += 1
      
        j += 1
        
  
    print(i == len(s1))

