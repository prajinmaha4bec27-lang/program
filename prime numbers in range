def find_primes_in_range(start, end):
    prime_numbers = []
    
    
    for num in range(max(2, start), end + 1):
       
        for i in range(2, int(num ** 0.5) + 1):
            if num % i == 0:
                break 
        else:
        
            prime_numbers.append(num)
            
    return prime_numbers


lower_bound = 10
upper_bound = 50
result = find_primes_in_range(lower_bound, upper_bound)

print(f"Prime numbers between {lower_bound} and {upper_bound}: {result}")

